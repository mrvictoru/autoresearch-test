{
  "goal": "Improve the restaurant inventory policy while preserving the immutable benchmark.",
  "constraints": {
    "experiment_command": [
      "{python}",
      "-m",
      "autoresearch.experiments.restaurant_eval",
      "--experiment",
      "autoresearch/experiments/restaurant_train.py"
    ]
  },
  "allowed_mutable_files": [
    "autoresearch/experiments/restaurant_train.py"
  ],
  "immutable_files": [
    "autoresearch/experiments/restaurant_eval.py",
    "autoresearch/tasks.py",
    "program.md",
    "AGENTS.md"
  ],
  "time_budget_seconds": 1800,
  "tie_breaker_policy": "Prefer higher score; ties are discarded."
}
